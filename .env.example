# ─────────────────────────────────────────────────────────────
# Real-Time Sports Analytics Platform — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Network / Machine IPs ─────────────────────────────────────
MAIN_MACHINE_IP=192.168.1.10
NODE1_IP=192.168.1.11
NODE2_IP=192.168.1.12
NODE3_IP=192.168.1.13
NODE4_IP=192.168.1.14
NODE5_IP=192.168.1.15

# ── Kafka ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=192.168.1.12:9092,192.168.1.13:9092,192.168.1.14:9092
KAFKA_TOPIC_TENNIS=tennis-events
KAFKA_TOPIC_F1=f1-telemetry
KAFKA_REPLICATION_FACTOR=3
KAFKA_NUM_PARTITIONS=3

# ── TimescaleDB ───────────────────────────────────────────────
TIMESCALE_HOST=192.168.1.15
TIMESCALE_PORT=5432
TIMESCALE_DB=sports_analytics
TIMESCALE_USER=analytics_user
TIMESCALE_PASSWORD=changeme_strong_password

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=192.168.1.14
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# ── AI Engine ─────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:7b
CHROMA_HOST=localhost
CHROMA_PORT=8000
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── FastAPI ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=changeme_jwt_secret
CORS_ORIGINS=http://192.168.1.12:3000,http://localhost:3000

# ── Prometheus ────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# ── Spark ─────────────────────────────────────────────────────
SPARK_MASTER=spark://192.168.1.13:7077
SPARK_BATCH_INTERVAL_SECONDS=2
